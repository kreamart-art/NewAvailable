# Verplicht: lange willekeurige string. Genereer er een met:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=verander-mij-in-een-lange-willekeurige-string

# Poort waarop de server draait
PORT=4000

# Toegestane frontend-oorsprong(en), komma-gescheiden. Gebruik in productie geen *.
# Bijvoorbeeld de dev-server van Vite:
CORS_ORIGIN=http://localhost:5173

# Optioneel: pad naar het SQLite-bestand
# DB_FILE=budget.db

# --- Pushberichten (web-push) ---
# Genereer eenmalig een sleutelpaar met:
#   npx web-push generate-vapid-keys
# en plak de waarden hieronder. Laat ze leeg om push uit te zetten.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contactadres dat aan de pushdienst wordt doorgegeven (mailto: of https-URL):
VAPID_SUBJECT=mailto:jij@voorbeeld.nl
